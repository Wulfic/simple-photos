+// ── Helpers ──────────────────────────────────────────────────────────────────
+
+/** Format seconds as MM:SS or HH:MM:SS */
+private fun formatTrimTime(secs: Float): String {
+    val s = secs.coerceAtLeast(0f).toInt()
+    val h = s / 3600
+    val m = (s % 3600) / 60
+    val sec = s % 60
+    return if (h > 0) "%d:%02d:%02d".format(h, m, sec) else "%d:%02d".format(m, sec)
+}

# =============================================================================
# Simple Photos — Root .gitignore
# =============================================================================

# ── Secrets & Environment ────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.crt
*.p12
*.jks
*.keystore
.mcp.json

# ── Server (Rust / Cargo) ────────────────────────────────────────────────────
server/target/
# Use config.example.toml as the committed template; config.toml holds local secrets
server/config.toml
# Runtime DB, blob storage, TLS certs, and AI models (can be huge)
server/data/
server/models/
server/certs/
**/*.rs.bk
install.sh.bak
# NOTE: server/Cargo.lock IS committed (this is a binary application — pinning
# transitive deps is required for reproducible release builds).

# ── Web (Node / Vite) ────────────────────────────────────────────────────────
node_modules/
web/dist/
web/.vite/
web/.parcel-cache/
*.tsbuildinfo

# ── Android (Gradle) ─────────────────────────────────────────────────────────
android/.gradle/
android/local.properties
android/app/release/
android/app/*.aab
android/app/*.apk
android/**/*.apk
android/**/*.aab
android/build/
android/app/build/
android/**/build/
android/.idea/
android/*.iml
android/**/*.iml
android/.DS_Store
android/keystore/
android/signing.properties
android/google-services.json   # if ever added

# ── IDE & Editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/settings.json
.vscode/launch.json
*.suo
*.user
*.userosscache
*.sln.docstates
nbproject/
.project
.classpath
.settings/
*.swp
*~
\#*\#
.#*

# ── OS Generated ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ── Network Drive Artifacts ──────────────────────────────────────────────────
# SMB / Samba / CIFS temporary and lock files
.~lock.*
*.lnk
~$*
desktop.ini
# NFS temporary files
.nfs*
# Synology / QNAP NAS metadata
@eaDir/
#recycle/
.AppleDouble/
.LSOverrideWasEmpty

# ── Docker ───────────────────────────────────────────────────────────────────
# Docker volumes are managed outside git; don't accidentally commit runtime data
docker-compose.override.yml
docker-instances/

# ── Logs & Runtime ───────────────────────────────────────────────────────────
*.log
logs/
*.pid
*.seed
*.pid.lock
coverage/
.nyc_output/

# ── Compiled / Generated ─────────────────────────────────────────────────────
*.o
*.so
*.dylib
*.dll
*.class
*.jar
# Gradle wrapper jar must be committed so CI can run ./gradlew without
# bootstrapping Gradle separately.
!android/gradle/wrapper/gradle-wrapper.jar
__pycache__/
*.pyc
downloads/simple-photos.apk
references/
.gitnexus

# ── Benchmark results ─────────────────────────────────────────────────────────
benchmark_results/

# ── Python virtual environments ─────────────────────────────────────────────
.venv/
venv/
env/
.python-version
.pytest_cache/
.tox/

# ── Test artifacts ──────────────────────────────────────────────────────────
# Network-fetched AI sample assets (face grouping etc.) — generated on demand
tests/test_data/downloaded_*/
tests/.cache/



.claude/
.mcp.json
CLAUDE.md
# NOTE: do NOT ignore .github/ — the entire CI pipeline (workflows, CodeQL
# config, skills) is version-controlled there. A blanket ".github/" ignore
# silently drops any NEW file under it from commits, so it never reaches the
# release checkout (this is exactly how .github/codeql/codeql-config.yml went
# missing on the v1.3.4 release run).
.vscode/
# NOTE: .vscode/mcp.json was previously force-added past this rule and leaked
# internal LAN topology (IPs/ports/host paths). Never `git add -f` files in
# here — keep local-only editor/MCP config out of the repo.

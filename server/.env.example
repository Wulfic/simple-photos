# Simple Photos Server — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed to version control.
#
# Environment variables override the corresponding config.toml values.
# Format: SIMPLE_PHOTOS_<SECTION>_<KEY>=value

# ── Config file path (optional, defaults to ./config.toml) ──────────────────
SIMPLE_PHOTOS_CONFIG=./config.toml

# ── Server ───────────────────────────────────────────────────────────────────
SIMPLE_PHOTOS_SERVER_HOST=0.0.0.0
SIMPLE_PHOTOS_SERVER_PORT=3000
SIMPLE_PHOTOS_SERVER_BASE_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
SIMPLE_PHOTOS_DATABASE_PATH=./data/db/simple-photos.db
SIMPLE_PHOTOS_DATABASE_MAX_CONNECTIONS=5

# ── Storage ──────────────────────────────────────────────────────────────────
# Local path:        ./data/storage
# Network/SMB mount: /mnt/vault/Files/Simple-Photos
#   (mount the SMB share first: sudo mount -t cifs //vault.local/vault /mnt/vault ...)
SIMPLE_PHOTOS_STORAGE_ROOT=./data/storage
SIMPLE_PHOTOS_STORAGE_DEFAULT_QUOTA_BYTES=10737418240
SIMPLE_PHOTOS_STORAGE_MAX_BLOB_SIZE_BYTES=5368709120

# ── Auth — CHANGE THESE IN PRODUCTION ────────────────────────────────────────
# Generate with: openssl rand -hex 32
SIMPLE_PHOTOS_AUTH_JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_HEX
SIMPLE_PHOTOS_AUTH_ACCESS_TOKEN_TTL_SECS=3600
SIMPLE_PHOTOS_AUTH_REFRESH_TOKEN_TTL_DAYS=30
SIMPLE_PHOTOS_AUTH_ALLOW_REGISTRATION=true
SIMPLE_PHOTOS_AUTH_BCRYPT_COST=12

# ── Web Frontend ─────────────────────────────────────────────────────────────
SIMPLE_PHOTOS_WEB_STATIC_ROOT=../web/dist

# ── Rust Log Level ───────────────────────────────────────────────────────────
RUST_LOG=info

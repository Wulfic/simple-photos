<?xml version="1.0" encoding="UTF-8"?>
<!-- Copyright 2026 WulfNet Designs -->
<component type="desktop-application">
  <id>io.github.wulfic.SimplePhotos</id>

  <!-- Populates "License" in GNOME Software / app stores. Matches LICENSE. -->
  <project_license>MIT</project_license>
  <metadata_license>CC0-1.0</metadata_license>

  <!-- Associates this AppStream component with the binary package. Without it
       the installer (Ubuntu App Center / GNOME Software) can't link the local
       .deb to this metadata and falls back to bare dpkg control fields, which
       have no license and no rich icon -> "unknown" publisher/license, no icon.
       MUST match the .deb package name (Cargo.toml [package.metadata.deb].name). -->
  <pkgname>simple-photos</pkgname>

  <name>Simple Photos</name>
  <!-- The short, one-line "description" shown in store listings. Keep concise:
       no install steps, no marketing paragraphs. -->
  <summary>Self-hosted, end-to-end encrypted photo and video library</summary>

  <!-- Populates "Publisher" / developer. The modern <developer><name> block is
       what AppStream >= 0.16 / libappstream 1.0 (Ubuntu 24.04+) reads; the
       legacy <developer_name> below is kept for older appstream releases. -->
  <developer id="io.github.wulfic">
    <name>WulfNet Designs</name>
  </developer>
  <developer_name>WulfNet Designs</developer_name>

  <description>
    <p>
      Simple Photos is a private alternative to cloud photo services that you
      run on your own hardware. Your library stays end-to-end encrypted and
      never leaves your control.
    </p>
    <p>It includes:</p>
    <ul>
      <li>On-device AI face and object recognition</li>
      <li>Offline reverse geocoding of photo locations</li>
      <li>Multi-user accounts with shared and private albums</li>
      <li>Automatic encrypted backup from the companion Android app</li>
      <li>An installable Progressive Web App with optional HTTPS</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.github.wulfic.SimplePhotos.desktop</launchable>
  <!-- stock: resolved from the installed hicolor theme (post-install app menu).
       remote: a URL the installer can fetch so the icon renders in the store /
       .deb preview *before* the local icon theme cache is updated. Both point
       at the same simple-photos icon asset. -->
  <icon type="stock">simple-photos</icon>
  <icon type="remote" width="256" height="256">https://raw.githubusercontent.com/Wulfic/simple-photos/main/packaging/debian/simple-photos-256.png</icon>

  <url type="homepage">https://github.com/Wulfic/simple-photos</url>
  <url type="bugtracker">https://github.com/Wulfic/simple-photos/issues</url>

  <categories>
    <category>Graphics</category>
    <category>Photography</category>
  </categories>

  <!-- GNOME Software treats a component with no <releases> as low quality and
       may suppress its rich metadata. Keep the latest release listed here;
       bump-version tooling can append new entries. -->
  <releases>
    <release version="1.3.49" date="2026-06-15"/>
  </releases>

  <content_rating type="oars-1.1" />
</component>
